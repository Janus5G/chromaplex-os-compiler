<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChromaPlex OS - 3D Simulator</title>
    <style>
        body { margin: 0; overflow: hidden; background-color: #050505; color: #00ff41; font-family: 'Courier New', Courier, monospace; }
        #ui-container { position: absolute; top: 20px; left: 20px; background: rgba(0, 20, 0, 0.8); border: 1px solid #00ff41; padding: 20px; border-radius: 5px; width: 320px; box-shadow: 0 0 15px rgba(0, 255, 65, 0.2); z-index: 10; }
        h1 { font-size: 1.2rem; text-shadow: 0 0 5px #00ff41; margin-top: 0; border-bottom: 1px dashed #00ff41; padding-bottom: 10px; }
        label { display: block; margin-top: 10px; font-weight: bold; font-size: 0.9rem; }
        input[type="range"], input[type="number"], select { width: 100%; background: #000; color: #00ff41; border: 1px solid #00ff41; padding: 5px; margin-top: 5px; box-sizing: border-box; }
        button { background: #00ff41; color: #000; border: none; padding: 10px; width: 100%; margin-top: 15px; cursor: pointer; font-weight: bold; text-transform: uppercase; }
        button:hover { background: #fff; box-shadow: 0 0 10px #00ff41; }
        #terminal { margin-top: 20px; background: #000; border: 1px solid #00ff41; height: 150px; overflow-y: auto; padding: 10px; font-size: 0.8rem; }
        .log-entry { margin-bottom: 5px; }
        .color-UV { color: #9B30FF; }
        .color-Violet { color: #8A2BE2; }
        .color-Blå { color: #1E90FF; }
        .color-Grøn { color: #00FF41; }
        .color-Rød { color: #FF3333; }
    </style>
</head>
<body>
    <div id="ui-container">
        <h1>ChromaPlex OS_Terminal</h1>
        
        <label>Voxel X: <span id="valX">5</span></label>
        <input type="range" id="coordX" min="0" max="9" value="5">
        
        <label>Voxel Y: <span id="valY">5</span></label>
        <input type="range" id="coordY" min="0" max="9" value="5">
        
        <label>Voxel Z: <span id="valZ">5</span></label>
        <input type="range" id="coordZ" min="0" max="9" value="5">

        <label>Bølgelængde Kanal</label>
        <select id="channelSelect">
            <option value="UV" class="color-UV">UV (350nm)</option>
            <option value="Violet" class="color-Violet">Violet (405nm)</option>
            <option value="Blå" class="color-Blå">Blå (473nm)</option>
            <option value="Grøn" class="color-Grøn" selected>Grøn (532nm)</option>
            <option value="Rød" class="color-Rød">Rød (650nm)</option>
        </select>

        <label>Data Værdi (Heltal)</label>
        <input type="number" id="dataInput" value="1234567">

        <button id="btnWrite">STORE.ANGLES (Skriv)</button>
        <button id="btnRead">LOAD.PLANE (Læs)</button>

        <div id="terminal">
            <div class="log-entry">> System initialiseret...</div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);

        const geometry = new THREE.BoxGeometry(10, 10, 10);
        const edges = new THREE.EdgesGeometry(geometry);
        const material = new THREE.LineBasicMaterial({ color: 0x00ff41, transparent: true, opacity: 0.3 });
        const crystalOutline = new THREE.LineSegments(edges, material);
        crystalOutline.position.set(4.5, 4.5, 4.5); 
        scene.add(crystalOutline);

        const targetGeo = new THREE.BoxGeometry(1.1, 1.1, 1.1);
        const targetMat = new THREE.MeshBasicMaterial({ color: 0xffffff, wireframe: true, transparent: true, opacity: 0.8 });
        const targetMesh = new THREE.Mesh(targetGeo, targetMat);
        scene.add(targetMesh);

        const storage = {}; 
        const colorMap = { "UV": 0x9B30FF, "Violet": 0x8A2BE2, "Blå": 0x1E90FF, "Grøn": 0x00FF41, "Rød": 0xFF3333 };

        camera.position.set(15, 15, 20);
        camera.lookAt(4.5, 4.5, 4.5);

        function updateTarget() {
            const x = parseInt(document.getElementById('coordX').value);
            const y = parseInt(document.getElementById('coordY').value);
            const z = parseInt(document.getElementById('coordZ').value);
            targetMesh.position.set(x, y, z);
            document.getElementById('valX').innerText = x;
            document.getElementById('valY').innerText = y;
            document.getElementById('valZ').innerText = z;
        }

        ['coordX', 'coordY', 'coordZ'].forEach(id => {
            document.getElementById(id).addEventListener('input', updateTarget);
        });
        updateTarget();

        function log(msg, colorClass = "") {
            const term = document.getElementById('terminal');
            term.innerHTML += `<div class="log-entry ${colorClass}">> ${msg}</div>`;
            term.scrollTop = term.scrollHeight;
        }

        function encodeData(value) {
            let e = 0;
            while (Math.pow(2, e + 1) <= value && value > 0) e++;
            const rest = value - Math.pow(2, e);
            return { e, rest };
        }

        document.getElementById('btnWrite').addEventListener('click', () => {
            const x = targetMesh.position.x; const y = targetMesh.position.y; const z = targetMesh.position.z;
            const channel = document.getElementById('channelSelect').value;
            const value = parseInt(document.getElementById('dataInput').value);
            
            if(isNaN(value) || value < 0) return log("Fejl: Ugyldig data værdi.", "color-Rød");

            const { e, rest } = encodeData(value);
            const key = `${x},${y},${z}`;
            if(!storage[key]) storage[key] = {};
            storage[key][channel] = { e, rest };

            const voxelGeo = new THREE.BoxGeometry(0.8, 0.8, 0.8);
            const voxelMat = new THREE.MeshBasicMaterial({ color: colorMap[channel], transparent: true, opacity: 0.6 });
            const voxel = new THREE.Mesh(voxelGeo, voxelMat);
            voxel.position.set(x, y, z);
            scene.add(voxel);

            log(`Skriver vha. angulær multipleksing...`, `color-${channel}`);
            log(`Voxel (${x},${y},${z}) [${channel}] = 2^${e} + ${rest}`, `color-${channel}`);
        });

        document.getElementById('btnRead').addEventListener('click', () => {
            const x = targetMesh.position.x; const y = targetMesh.position.y; const z = targetMesh.position.z;
            const channel = document.getElementById('channelSelect').value;
            const key = `${x},${y},${z}`;

            log(`Henter 2D plan asynkront...`);
            if(storage[key] && storage[key][channel]) {
                const data = storage[key][channel];
                const reconstructed = Math.pow(2, data.e) + data.rest;
                log(`Læst fra (${x},${y},${z}) [${channel}]:`, `color-${channel}`);
                log(`Rå: e=${data.e}, rest=${data.rest} -> Værdi: ${reconstructed}`, `color-${channel}`);
            } else {
                log(`Voxel (${x},${y},${z}) [${channel}] er tom.`);
            }
        });

        function animate() {
            requestAnimationFrame(animate);
            crystalOutline.rotation.y += 0.001; 
            scene.children.forEach(child => {
                if(child !== crystalOutline && child !== targetMesh && child.type === "Mesh") {
                    child.rotation.y = crystalOutline.rotation.y;
                }
            });
            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            renderer.setSize(window.innerWidth, window.innerHeight);
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
        });
    </script>
</body>
</html>
